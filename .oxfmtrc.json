{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 140,
	"singleQuote": true,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"singleAttributePerLine": false,
	"sortImports": true,
	"sortPackageJson": true,
	"ignorePatterns": [
		"**/dist/**",
		"**/.output/**",
		"**/node_modules/**",
		"**/wrangler/**",
		"**/.agents/skills/**",
		"skills-lock.json",
		"worker-configuration.d.ts"
	]
}
