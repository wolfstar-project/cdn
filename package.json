{
	"name": "worker-r2-cdn",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "vite build && wrangler deploy --config .output/server/wrangler.json",
		"format": "biome format --write --no-errors-on-unmatched .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@cloudflare/workers-types": "^4.20260412.1",
		"husky": "^9.1.7",
		"typescript": "^5.9.2",
		"vite": "^8.0.8",
		"wrangler": "^4.81.1"
	},
	"packageManager": "pnpm@10.33.0",
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": ["biome format --write --no-errors-on-unmatched"],
		"*": ["biome format --no-errors-on-unmatched --files-ignore-unknown=true"]
	},
	"dependencies": {
		"evlog": "^2.13.0",
		"nitro": "3.0.260415-beta"
	}
}
